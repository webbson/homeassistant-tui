{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": {"tool": "Edit|Write", "file_pattern": ".*\\.rs$"},
        "command": "cd /Users/tom.stevens/git/homeassistant-tui && cargo fmt && cargo clippy --all-targets --quiet 2>&1 | head -30"
      }
    ],
    "PreToolUse": [
      {
        "matcher": {"tool": "Write", "file_pattern": ".*\\.(env|token).*|config/.*\\.yaml$"},
        "command": "echo 'Blocked: potential token/config file' && exit 1"
      }
    ]
  }
}
